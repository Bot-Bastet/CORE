
<robot name="quadruped">
    <link name="base_link">
        <visual>
            <geometry>
                <box size="0.8 0.5 0.07"/>
            </geometry>
            <material name="grey">
                <color rgba="0.5 0.5 0.5 1"/>
            </material>
        </visual>
        <collision>
            <geometry>
                <box size="0.8 0.5 0.07"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="4.0"/>
            <inertia ixx="0.1" ixy="0" ixz="0" iyy="0.1" iyz="0" izz="0.1"/>
        </inertial>
    </link>

    <!-- FL Leg -->
    <joint name="FL_hip_joint" type="revolute">
        <parent link="base_link"/>
        <child link="FL_thigh"/>
        <origin xyz="0.4 0.25 -0.085" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-1.57" upper="1.57" effort="12.0" velocity="100"/>
    </joint>

    <link name="FL_thigh">
        <visual>
            <origin xyz="0 0 -0.1625" rpy="0 0 0"/>
            <geometry>
                <capsule radius="0.03" length="0.325"/>
            </geometry>
            <material name="orange">
                <color rgba="0.8 0.5 0.2 1"/>
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 -0.1625" rpy="0 0 0"/>
            <geometry>
                <capsule radius="0.03" length="0.325"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.4"/>
            <origin xyz="0 0 -0.1625" rpy="0 0 0"/>
            <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
        </inertial>
    </link>

    <joint name="FL_knee_joint" type="revolute">
        <parent link="FL_thigh"/>
        <child link="FL_shin"/>
        <origin xyz="0 0 -0.325" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="0" upper="2.6" effort="12.0" velocity="100"/>
    </joint>

    <link name="FL_shin">
        <visual>
            <origin xyz="0 0 -0.1625" rpy="0 0 0"/>
            <geometry>
                <capsule radius="0.028" length="0.325"/>
            </geometry>
            <material name="orange"/>
        </visual>
        <collision>
            <origin xyz="0 0 -0.1625" rpy="0 0 0"/>
            <geometry>
                <capsule radius="0.028" length="0.325"/>
            </geometry>
        </collision>
        <inertial>
            <mass value="0.3"/>
            <origin xyz="0 0 -0.1625" rpy="0 0 0"/>
            <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
        </inertial>
    </link>
    <joint name="FL_foot_joint" type="fixed">
        <parent link="FL_shin"/>
        <child link="FL_foot"/>
        <origin xyz="0 0 -0.325" rpy="0 0 0"/>
    </joint>

    <link name="FL_foot">
        <visual>
            <geometry><sphere radius="0.03"/></geometry>
            <material name="grey"/>
        </visual>
        <collision>
            <geometry><sphere radius="0.03"/></geometry>
        </collision>
        <inertial>
            <mass value="0.05"/>
            <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
        </inertial>
    </link>

